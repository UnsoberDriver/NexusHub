# Configuration pour Render
# Copie ce fichier en .env et remplis les valeurs

# Base de données - À RÉCUPÉRER DEPUIS RENDER
# Tu trouveras DATABASE_URL dans l'onglet "Environment" de Render
DATABASE_URL=postgresql://user:password@host:port/database

# Alternative : Variables individuelles (si tu ne veux pas utiliser DATABASE_URL)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=nexus_pulse
DB_PORT=3306

# Application
APP_NAME=Nexus Pulse
APP_ENV=production
DEBUG=false
